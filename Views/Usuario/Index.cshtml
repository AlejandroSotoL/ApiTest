@{
    ViewData["Title"] = "Home Page";
}

<div
    class="bg-gradient-to-br from-[#1a567b] via-[#1a567b]/90 to-[#1a567b]/80  p-8 rounded-4xl border-2 border-[#20a9e5] shadow-2xl w-96">
    <h2 class="text-2xl font-bold text-center text-white mb-20 mt-10">Iniciar Sesión</h2>

    <form id="loginForm" class="space-y-5">
        <div>
            <div
                class="flex items-center gap-4 bg-[#10243c] p-3 text-white rounded-md focus-within:ring-2 focus-within:ring-cyan-400">
                <i class="material-icons text-gray-300">lock</i>
        
                <input type="text" name="Username" placeholder="Usuario"
                       class="w-full bg-transparent outline-none border-none text-white placeholder-gray-400" />
            </div>

            <span data-for="Username" class="text-red-500 text-xs mt-1 block"></span>
            
        </div>
        <div>
            <div
                class="flex items-center gap-4 bg-[#10243c] p-3 text-white rounded-md focus-within:ring-2 focus-within:ring-cyan-400">
                <i class="material-icons text-gray-300">lock</i>
        
                <input type="password" name="Password" placeholder="********"
                       class="w-full bg-transparent outline-none border-none text-white placeholder-gray-400" />
            </div>

            <span data-for="Password" class="text-red-500 text-xs mt-1 block"></span>
            
        </div>
        <div class="flex justify-between text-sm text-white my-10">
            <div>
                <input type="checkbox" name="Recordarme" />
                <label for="Recordarme">Recordarme</label>
            </div>
            <div>
                <a href="/Usuario/Registro">Olvidaste tu contraseña?</a>
            </div>
            
        </div>
        <button type="submit"
                class="w-full bg-[#10243c] text-white p-3 rounded-lg font-semibold hover:bg-[#116a91] transition">
            Ingresar
        </button>
    </form>

    <div id="mensaje" class="text-center my-8 text-sm font-medium"></div>
</div>


@section Scripts {
    <script src="~/js/index.js"></script>
}
