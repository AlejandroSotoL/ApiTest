{
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./wwwroot/css/site.css -o ./wwwroot/css/output.css --watch",
    "start:api": "dotnet watch run --project ./api.csproj",
    "dev": "concurrently \"npm run build:css\" \"npm run start:api\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19"
  }
}
